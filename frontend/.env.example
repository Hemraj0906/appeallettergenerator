# AppealLetterGenerator.com - Environment Variables
# Copy this file to .env.local and fill in your values

# ── OpenAI (for AI-powered letter generation) ──────────────
# Get your API key at https://platform.openai.com/api-keys
# If not set, the app uses template-based letter generation (still works great!)
OPENAI_API_KEY=

# ── Resend (for one-click email sending) ───────────────────
# Get your API key at https://resend.com
# If not set, emails are mocked (letter still generated for copy/paste)
RESEND_API_KEY=

# ── Supabase (optional - for analytics/storage) ───────────
# Get your credentials at https://supabase.com
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── Site Configuration ─────────────────────────────────────
SITE_URL=https://appeallettergenerator.com
NEXT_PUBLIC_SITE_URL=https://appeallettergenerator.com

# ── Google AdSense ─────────────────────────────────────────
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXX

# ── Google Analytics ───────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
